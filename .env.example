NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=autofluxo_user
DB_PASSWORD=secure_password_here
DB_NAME=autofluxo

JWT_SECRET=your_very_secret_key_with_at_least_32_characters_here

OPENAI_API_KEY=your_openai_api_key_here

# Senha da role Postgres read-only (autofluxo_readonly), usada SÓ pela busca IA.
# A migration cria/atualiza a role com este valor; a 2a DataSource conecta com
# ela (GRANT SELECT restrito; sem senhaHash nem refresh_tokens). Sem esta var a
# busca por IA fica indisponível (503). Gere com: openssl rand -hex 24
DB_READONLY_PASSWORD=
