# ─────────────────────────────────────────────────────────────────────────────
# AutoFluxo — variáveis de PRODUÇÃO. Copie para .env.production e preencha.
# NUNCA comite .env.production (já está no .gitignore).
# Suba sempre com:  docker compose --env-file .env.production -f docker-compose.prod.yml ...
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000

# Liga HSTS + redirect de fallback http->https no backend (o TLS termina no nginx).
HTTPS=true

# Origem(ns) permitida(s): o host por onde o sistema é acessado, com https://.
# Lista separada por vírgula. Ex.: https://app.automix.local
CORS_ORIGIN=https://CHANGE_ME

# Segredo de assinatura dos JWT — mínimo 32 chars. Gere com: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# Banco. Dentro do compose o host é "db" (o serviço app sobrescreve DB_HOST=db).
# O serviço db usa DB_NAME/DB_USER/DB_PASSWORD para inicializar o Postgres.
DB_HOST=db
DB_PORT=5432
DB_USER=autofluxo_user
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=autofluxo

# Senha da role read-only do Postgres p/ a busca por IA (opcional).
# Gere com: openssl rand -hex 24
DB_READONLY_PASSWORD=

# Chave da OpenAI p/ a busca por IA (opcional).
OPENAI_API_KEY=
