{
  "name": "autofluxo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only backend/src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "lint": "eslint backend/src --ext .ts",
    "format": "prettier --write \"backend/src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "migrate:up": "ts-node -r tsconfig-paths/register -r dotenv/config ./node_modules/typeorm/cli.js migration:run -d backend/src/lib/database.ts",
    "migrate:down": "ts-node -r tsconfig-paths/register -r dotenv/config ./node_modules/typeorm/cli.js migration:revert -d backend/src/lib/database.ts",
    "migrate:seed": "ts-node -r tsconfig-paths/register -r dotenv/config backend/src/seeds/index.ts"
  },
  "prepare": "husky install",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "pino": "^8.14.1",
    "pino-http": "^8.4.1",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.20",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.5.0",
    "@commitlint/config-conventional": "^17.5.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.1",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "pino-pretty": "^10.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
