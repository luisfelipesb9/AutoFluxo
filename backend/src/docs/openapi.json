{
  "openapi": "3.0.0",
  "info": {
    "title": "AutoFluxo API",
    "version": "1.0.0",
    "description": "API para autenticação e fluxo de exemplo."
  },
  "servers": [
    { "url": "/api" }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "login": { "type": "string" },
                  "senha": { "type": "string" }
                },
                "required": ["login", "senha"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Success" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  }
}
